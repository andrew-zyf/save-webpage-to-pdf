{
  "manifest_version": 3,
  "name": "Save WSJ Webpage to PDF",
  "version": "1.1.1",
  "description": "一键将 WSJ 文章重构为竖向 A4 PDF：自动抽取标题/作者/正文，清理网页控件与推荐流。",
  "permissions": ["activeTab", "scripting", "contextMenus"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save WSJ Webpage to PDF"
  },
  "commands": {
    "save-pdf": {
      "suggested_key": {
        "default": "Alt+Shift+P",
        "mac": "Alt+Shift+P"
      },
      "description": "保存 WSJ 文章为竖向 A4 PDF"
    }
  },
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
